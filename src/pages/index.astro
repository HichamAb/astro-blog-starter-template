---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const PRODUCT = {
  name:        'HOCO J101B Astute',
  capacity:    '30000mAh',
  power:       '22.5W',
  price:       4900,
  oldPrice:    6200,
  discount:    36,
  currency:    'دج',
  stock:       47,
  delivery:    '24 - 72 ساعة',
};

const FEATURES = [
  { icon: '⚡', title: 'شحن فائق السرعة 22.5W', desc: 'يشحن هاتفك من 0 إلى 100% في وقت قياسي بتقنية QC 3.0' },
  { icon: '🔋', title: 'طاقة ضخمة 30000mAh', desc: 'تكفي لشحن هاتفك أكثر من 6 مرات متتالية دون انقطاع' },
  { icon: '📱', title: 'متعدد المنافذ', desc: 'USB-A × 2 + USB-C، اشحن أجهزة متعددة في نفس الوقت' },
  { icon: '🛡️', title: 'حماية ذكية شاملة', desc: 'حماية من الشحن الزائد، والحرارة، وقصر الدارة الكهربائية' },
  { icon: '💡', title: 'شاشة LED ذكية', desc: 'تعرض نسبة الشحن المتبقية بدقة في أي وقت' },
  { icon: '✈️', title: 'مثالي للسفر', desc: 'متين، خفيف الوزن، يناسب جميع مناسبات التنقل' },
];

const SPECS = [
  { label: 'السعة',           value: '30000mAh / 111Wh' },
  { label: 'الشحن الخارج',    value: 'USB-C PD 22.5W | USB-A QC3.0 18W' },
  { label: 'الشحن الداخل',    value: 'USB-C 22.5W | Micro-USB 18W' },
  { label: 'عدد المنافذ',     value: '3 منافذ (2×USB-A + 1×USB-C)' },
  { label: 'شاشة العرض',      value: 'LED رقمية بنسبة مئوية' },
  { label: 'الأبعاد',         value: '163 × 76 × 28 مم' },
  { label: 'الوزن',           value: '521 غرام' },
  { label: 'اللون',           value: 'أسود' },
];

const TESTIMONIALS = [
  {
    name: 'أحمد بن علي',
    wilaya: 'الجزائر العاصمة',
    rating: 5,
    text: 'باور بانك خرافي! شحنت تيليفوني 5 مرات ما خلاش. الشحن السريع رهيب، الجودة تستاهل كل درهم 🔥',
    avatar: '👨',
  },
  {
    name: 'سارة محمودي',
    wilaya: 'وهران',
    rating: 5,
    text: 'طلبته وصلني في يومين، التغليف ممتاز والمنتج أصلي 100%. نوصي بيه لكل واحد يسافر كثير',
    avatar: '👩',
  },
  {
    name: 'كريم بوعلام',
    wilaya: 'قسنطينة',
    rating: 5,
    text: 'قريت الريفيو ترددت، لكن الصراحة فاق التوقعات. اللمسة الراقية والأداء ما يخيبش. برافو!',
    avatar: '👨‍💼',
  },
];

const WILAYAS = [
  'أدرار','الشلف','الأغواط','أم البواقي','باتنة','بجاية','بسكرة','بشار',
  'البليدة','البويرة','تمنراست','تبسة','تلمسان','تيارت','تيزي وزو','الجزائر',
  'الجلفة','جيجل','سطيف','سعيدة','سكيكدة','سيدي بلعباس','عنابة','قالمة',
  'قسنطينة','المدية','مستغانم','المسيلة','معسكر','ورقلة','وهران','البيض',
  'إليزي','برج بوعريريج','بومرداس','الطارف','تندوف','تيسمسيلت','الوادي',
  'خنشلة','سوق أهراس','تيبازة','ميلة','عين الدفلى','النعامة','عين تموشنت',
  'غرداية','غليزان','تيميمون','برج باجي مختار','أولاد جلال','بني عباس',
  'عين صالح','عين قزام','توقرت','جانت','المغير','المنيعة',
];
---

<Layout
  title="باور بانك HOCO J101B Astute 30000mAh | شحن سريع 22.5W | دفع عند الاستلام"
  description="اطلب الآن باور بانك هوكو J101B أستوت 30000mAh بشحن سريع 22.5W. التوصيل لجميع ولايات الجزائر، الدفع عند الاستلام. جودة أصلية مضمونة."
  price="3500"
>

<!-- ████ TOP TICKER ████ -->
<div class="ticker-wrap" aria-label="إعلان عرض">
  <div class="ticker-inner">
    {Array(2).fill([
      '🚚 توصيل سريع لجميع الولايات',
      '💳 الدفع عند الاستلام 100%',
      '✅ منتج أصلي مضمون',
      '⚡ شحن سريع 22.5W',
      '📦 تغليف محكم وآمن',
      '🎁 عرض محدود — اطلب الآن',
    ]).flat().map((item) => (
      <span class="ticker-item">
        {item}
        <span style="opacity:0.4">•</span>
      </span>
    ))}
  </div>
</div>

<!-- ████ HEADER ████ -->
<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <div class="logo">
        <!-- 
          🖼️ IMAGE: ضع شعارك هنا
          <img src="/images/logo.webp" alt="اسم متجرك" width="140" height="40" />
        -->
        <span class="logo-text">⚡ متجرك</span>
      </div>
      <div class="header-badges">
        <span class="badge badge-green">
          <span>✓</span> دفع عند الاستلام
        </span>
        <span class="badge badge-amber">
          <span>🚚</span> توصيل سريع
        </span>
      </div>
    </div>
  </div>
</header>

<!-- ████ HERO ████ -->
<section class="hero-section" aria-label="عرض المنتج الرئيسي">
  <div class="container">
    <div class="hero-grid">

      <!-- Hero Text -->
      <div class="hero-content">
        <div class="hero-badges">
          <span class="badge badge-red">🔥 عرض محدود</span>
          <span class="badge badge-amber">⚡ شحن سريع 22.5W</span>
        </div>

        <h1 class="hero-title">
          باور بانك
          <span class="brand-highlight">HOCO J101B</span>
          <br />
          <span class="capacity-tag">30000mAh</span>
          بطاقة خرافية!
        </h1>

        <p class="hero-desc">
          الرفيق المثالي للتنقل — يشحن هاتفك أكثر من <strong>6 مرات</strong>
          بتقنية الشحن السريع 22.5W. منتج أصلي مضمون، يوصلك لكل ولايات الجزائر
          بالدفع عند الاستلام.
        </p>

        <!-- Price Block -->
        <div class="price-block">
          <div class="price-row">
            <span class="price-current">{PRODUCT.price.toLocaleString('ar-DZ')} {PRODUCT.currency}</span>
            <span class="price-old">{PRODUCT.oldPrice.toLocaleString('ar-DZ')} {PRODUCT.currency}</span>
            <span class="price-badge">وفر {PRODUCT.discount}%</span>
          </div>
          <p class="price-note">
            💳 الدفع نقداً عند استلام الطرد — لا حاجة لبطاقة بنكية
          </p>
        </div>

        <!-- Trust Row -->
        <div class="trust-row">
          <div class="trust-item">
            <span class="trust-icon">🚚</span>
            <div>
              <strong>توصيل سريع</strong>
              <small>24 - 72 ساعة</small>
            </div>
          </div>
          <div class="trust-item">
            <span class="trust-icon">📦</span>
            <div>
              <strong>تغليف محكم</strong>
              <small>وصول آمن 100%</small>
            </div>
          </div>
          <div class="trust-item">
            <span class="trust-icon">🛡️</span>
            <div>
              <strong>ضمان أصالة</strong>
              <small>منتج أصلي مضمون</small>
            </div>
          </div>
        </div>

        <!-- Stock Warning -->
        <div class="stock-warning" role="alert">
          <span class="stock-dot"></span>
          <span>⚠️ متبقي <strong>{PRODUCT.stock} قطعة</strong> فقط في المخزن — اطلب قبل النفاد!</span>
        </div>

        <!-- CTA Button -->
        <a href="#order-form" class="btn-primary hero-cta" id="hero-cta-btn">
          <span>🛒</span>
          اطلب الآن — الدفع عند الاستلام
        </a>
      </div>

      <!-- Hero Image -->
      <div class="hero-image-wrap" aria-hidden="true">
        <div class="hero-image-glow"></div>
        <!--
          🖼️ IMAGE GUIDE:
          ضع صورة المنتج الرئيسية (PNG أو WebP بخلفية شفافة أو داكنة)
          الأبعاد المثالية: 600×600 بكسل
          المسار: /images/product-main.webp
          
          <img
            src="/images/product-main.webp"
            alt="باور بانك HOCO J101B Astute 30000mAh"
            width="560"
            height="560"
            fetchpriority="high"
            class="hero-img"
          />
        -->
        <div class="hero-img-placeholder" aria-label="صورة المنتج">
          <div class="placeholder-icon">🔋</div>
          <p>أضف صورة المنتج هنا<br /><code>/images/product-main.webp</code></p>
        </div>

        <!-- Floating badges on image -->
        <div class="float-badge float-top">
          <span>⚡ 22.5W</span>
        </div>
        <div class="float-badge float-bottom">
          <span>30000mAh</span>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ████ PRODUCT IMAGES GALLERY ████ -->
<section class="gallery-section section" aria-label="صور المنتج">
  <div class="container">
    <div class="section-header">
      <h2>شاهد المنتج عن قرب</h2>
      <div class="divider"></div>
    </div>
    <div class="gallery-grid">
      <!--
        🖼️ IMAGE GUIDE — صور إضافية:
        ضع 4 صور من زوايا مختلفة للمنتج
        الأبعاد: 400×400 بكسل، صيغة WebP
        
        <img src="/images/product-angle-1.webp" alt="باور بانك HOCO J101B - منفذ USB-C" class="gallery-img" loading="lazy" />
        <img src="/images/product-angle-2.webp" alt="باور بانك HOCO J101B - شاشة LED" class="gallery-img" loading="lazy" />
        <img src="/images/product-angle-3.webp" alt="باور بانك HOCO J101B - المنافذ" class="gallery-img" loading="lazy" />
        <img src="/images/product-angle-4.webp" alt="باور بانك HOCO J101B - الحجم" class="gallery-img" loading="lazy" />
      -->
      {['زاوية أمامية', 'شاشة LED', 'المنافذ', 'المنتج مفتوح'].map((label) => (
        <div class="gallery-placeholder">
          <span>📷</span>
          <p>{label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ████ FEATURES ████ -->
<section class="features-section section" aria-label="مميزات المنتج">
  <div class="container">
    <div class="section-header">
      <p class="section-eyebrow">لماذا تختاره؟</p>
      <h2>مميزات تجعله الأفضل في السوق</h2>
      <div class="divider"></div>
    </div>
    <div class="features-grid">
      {FEATURES.map((f) => (
        <article class="feature-card card" aria-label={f.title}>
          <div class="feature-icon">{f.icon}</div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ████ SPECS TABLE ████ -->
<section class="specs-section section" aria-label="المواصفات التقنية">
  <div class="container">
    <div class="specs-inner">
      <div class="section-header" style="text-align:right; margin-bottom:28px;">
        <p class="section-eyebrow">المواصفات التقنية</p>
        <h2>HOCO J101B Astute 30000mAh</h2>
      </div>
      <div class="specs-table" role="table" aria-label="جدول المواصفات">
        {SPECS.map((s, i) => (
          <div class="spec-row" role="row" style={i % 2 === 0 ? 'background:var(--bg-elevated)' : ''}>
            <span class="spec-label" role="rowheader">{s.label}</span>
            <span class="spec-value" role="cell">{s.value}</span>
          </div>
        ))}
      </div>

      <!-- CTA inside specs -->
      <div class="specs-cta">
        <a href="#order-form" class="btn-primary" style="max-width:360px; margin:0 auto;">
          <span>🛒</span> اطلب الآن بـ {PRODUCT.price.toLocaleString('ar-DZ')} {PRODUCT.currency} فقط
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ████ TESTIMONIALS ████ -->
<section class="testimonials-section section" aria-label="آراء العملاء">
  <div class="container">
    <div class="section-header">
      <p class="section-eyebrow">آراء العملاء</p>
      <h2>ماذا قالوا عن المنتج؟</h2>
      <div class="divider"></div>
      <div class="rating-summary" aria-label="متوسط التقييم">
        <div class="stars" aria-label="5 من 5 نجوم">★★★★★</div>
        <span>4.9/5 — من أكثر من 200 تقييم</span>
      </div>
    </div>
    <div class="testimonials-grid">
      {TESTIMONIALS.map((t) => (
        <article class="testimonial-card card" aria-label={`تقييم ${t.name}`}>
          <div class="testimonial-header">
            <div class="avatar" aria-hidden="true">{t.avatar}</div>
            <div>
              <strong class="reviewer-name">{t.name}</strong>
              <small class="reviewer-wilaya">📍 {t.wilaya}</small>
            </div>
            <div class="stars small" aria-label={`${t.rating} نجوم`}>
              {'★'.repeat(t.rating)}
            </div>
          </div>
          <p class="testimonial-text">"{t.text}"</p>
          <small class="verified-badge">✅ مشتري موثق</small>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ████ OFFER COUNTDOWN ████ -->
<section class="offer-section" aria-label="عرض مؤقت">
  <div class="container">
    <div class="offer-card">
      <p class="offer-eyebrow">🔥 عرض خاص محدود الوقت</p>
      <h2 class="offer-title">احصل عليه بسعر استثنائي الآن!</h2>
      <div class="price-row-big">
        <span class="price-big">{PRODUCT.price.toLocaleString('ar-DZ')} {PRODUCT.currency}</span>
        <del class="price-del">{PRODUCT.oldPrice.toLocaleString('ar-DZ')} {PRODUCT.currency}</del>
        <span class="discount-pill">وفر {PRODUCT.discount}%</span>
      </div>
      <div class="countdown-wrap" aria-live="polite" aria-atomic="true">
        <p class="countdown-label">⏳ العرض ينتهي خلال:</p>
        <div class="countdown" id="countdown">
          <div class="count-block"><span id="cd-h">00</span><small>ساعة</small></div>
          <div class="count-sep">:</div>
          <div class="count-block"><span id="cd-m">00</span><small>دقيقة</small></div>
          <div class="count-sep">:</div>
          <div class="count-block"><span id="cd-s">00</span><small>ثانية</small></div>
        </div>
      </div>
      <a href="#order-form" class="btn-primary" style="max-width:400px;">
        🛒 اطلب الآن — الدفع نقداً عند الاستلام
      </a>
    </div>
  </div>
</section>

<!-- ████ ORDER FORM ████ -->
<section class="order-section section" id="order-form" aria-label="نموذج الطلب">
  <div class="container">
    <div class="order-inner">

      <!-- Form Header -->
      <div class="section-header">
        <p class="section-eyebrow">🚀 خطوة واحدة فقط</p>
        <h2>أكمل طلبك الآن</h2>
        <div class="divider"></div>
        <p class="form-subtitle">
          أملأ البيانات ونتصل بك لتأكيد الطلب — الدفع عند الاستلام 💳
        </p>
      </div>

      <!-- Form -->
      <form
        id="cod-order-form"
        class="order-form"
        novalidate
        aria-label="نموذج الطلب بالدفع عند الاستلام"
      >
        <input type="hidden" name="product" value="HOCO J101B Astute 30000mAh" />
        <input type="hidden" name="price" value={PRODUCT.price} />
        <input type="hidden" name="_timestamp" value="" />

        <div class="form-grid">

          <!-- Full Name -->
          <div class="form-group" style="grid-column: 1 / -1;">
            <label for="full-name" class="form-label">
              <span>👤</span> الاسم الكامل <span class="required">*</span>
            </label>
            <input
              type="text"
              id="full-name"
              name="name"
              class="form-input"
              placeholder="مثال: أحمد بن علي"
              autocomplete="name"
              maxlength="80"
              required
            />
            <span class="form-error" id="name-error" role="alert">⚠ الرجاء إدخال الاسم الكامل</span>
          </div>

          <!-- Phone -->
          <div class="form-group">
            <label for="phone" class="form-label">
              <span>📱</span> رقم الهاتف <span class="required">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              class="form-input"
              placeholder="0X XX XX XX XX"
              autocomplete="tel"
              maxlength="13"
              inputmode="numeric"
              required
            />
            <span class="form-error" id="phone-error" role="alert">⚠ أدخل رقم هاتف صحيح (10 أرقام)</span>
          </div>

          <!-- Wilaya -->
          <div class="form-group">
            <label for="wilaya" class="form-label">
              <span>📍</span> الولاية <span class="required">*</span>
            </label>
            <select
              id="wilaya"
              name="wilaya"
              class="form-select"
              required
            >
              <option value="" disabled selected>اختر ولايتك</option>
              {WILAYAS.map((w, i) => (
                <option value={w}>{String(i + 1).padStart(2, '0')} - {w}</option>
              ))}
            </select>
            <span class="form-error" id="wilaya-error" role="alert">⚠ الرجاء اختيار الولاية</span>
          </div>

          <!-- Address -->
          <div class="form-group" style="grid-column: 1 / -1;">
            <label for="address" class="form-label">
              <span>🏠</span> العنوان التفصيلي <span class="required">*</span>
            </label>
            <textarea
              id="address"
              name="address"
              class="form-textarea"
              placeholder="مثال: حي الرحمة، شارع ابن باديس، رقم 12..."
              maxlength="300"
              required
            ></textarea>
            <span class="form-error" id="address-error" role="alert">⚠ الرجاء إدخال العنوان التفصيلي</span>
          </div>

          <!-- Quantity -->
          <div class="form-group">
            <label for="quantity" class="form-label">
              <span>🔢</span> الكمية
            </label>
            <select id="quantity" name="quantity" class="form-select">
              <option value="1" selected>1 قطعة</option>
              <option value="2">2 قطع</option>
              <option value="3">3 قطع</option>
            </select>
          </div>

          <!-- Notes -->
          <div class="form-group">
            <label for="notes" class="form-label">
              <span>📝</span> ملاحظات (اختياري)
            </label>
            <input
              type="text"
              id="notes"
              name="notes"
              class="form-input"
              placeholder="أي تفاصيل إضافية..."
              maxlength="200"
            />
          </div>

        </div>

        <!-- Order Summary -->
        <div class="order-summary" aria-label="ملخص الطلب">
          <div class="summary-row">
            <span>المنتج:</span>
            <strong>HOCO J101B Astute 30000mAh</strong>
          </div>
          <div class="summary-row">
            <span>السعر:</span>
            <strong class="summary-price">{PRODUCT.price.toLocaleString('ar-DZ')} {PRODUCT.currency}</strong>
          </div>
          <div class="summary-row">
            <span>التوصيل:</span>
            <strong class="text-green">مجاني 🚚</strong>
          </div>
          <div class="summary-row total-row">
            <span>المجموع:</span>
            <strong class="total-price" id="total-display">{PRODUCT.price.toLocaleString('ar-DZ')} {PRODUCT.currency}</strong>
          </div>
        </div>

        <!-- Submit -->
        <button type="submit" class="btn-primary submit-btn" id="submit-btn" aria-label="إرسال الطلب">
          <span class="btn-text">✅ أتمم طلبي الآن — الدفع عند الاستلام</span>
          <span class="btn-loading" style="display:none;">
            <span class="spinner"></span> جاري الإرسال...
          </span>
        </button>

        <p class="form-disclaimer">
          🔒 بياناتك محمية تماماً — سيتصل بك فريقنا لتأكيد الطلب
        </p>
      </form>

      <!-- Success Message -->
      <div class="success-msg" id="success-msg" role="alert" aria-live="polite" style="display:none;">
        <div class="success-icon">🎉</div>
        <h3>تم استلام طلبك بنجاح!</h3>
        <p>شكراً لك! سيتصل بك أحد أعضاء فريقنا في أقرب وقت لتأكيد الطلب والتوصيل.</p>
        <div class="success-detail">
          <span>📦 المنتج: HOCO J101B Astute 30000mAh</span>
          <span>🚚 التوصيل: خلال 24-72 ساعة</span>
          <span>💳 الدفع: نقداً عند الاستلام</span>
