<!-- ████ SCRIPTS ████ -->
<script define:vars={{ PRODUCT_PRICE: PRODUCT.price }}>

// ══ Countdown Timer ══
(function () {
  const end = new Date();
  end.setHours(23, 59, 59, 0);
  if (new Date() > end) end.setDate(end.getDate() + 1);

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const now  = new Date();
    const diff = Math.max(0, end - now);
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    const hEl = document.getElementById('cd-h');
    const mEl = document.getElementById('cd-m');
    const sEl = document.getElementById('cd-s');
    if (hEl) hEl.textContent = pad(h);
    if (mEl) mEl.textContent = pad(m);
    if (sEl) sEl.textContent = pad(s);
    if (diff > 0) requestAnimationFrame(tick);
  }
  tick();
})();

// ══ Dynamic Total ══
(function () {
  const qtyEl   = document.getElementById('quantity');
  const totalEl = document.getElementById('total-display');
  if (!qtyEl || !totalEl) return;
  qtyEl.addEventListener('change', () => {
    const qty   = parseInt(qtyEl.value, 10);
    const total = qty * PRODUCT_PRICE;
    totalEl.textContent = total.toLocaleString('ar-DZ') + ' دج';
  });
})();

// ══ Phone Format ══
(function () {
  const ph = document.getElementById('phone');
  if (!ph) return;
  ph.addEventListener('input', () => {
    ph.value = ph.value.replace(/[^0-9+\s]/g, '').slice(0, 13);
  });
})();

// ══ Form Validation & Submit ══
(function () {
  const form      = document.getElementById('cod-order-form');
  const submitBtn = document.getElementById('submit-btn');
  const successEl = document.getElementById('success-msg');
  const errorEl   = document.getElementById('error-msg');

  if (!form) return;

  // Set timestamp
  const tsInput = form.querySelector('[name="_timestamp"]');
  if (tsInput) tsInput.value = new Date().toISOString();

  // ── Validators ──
  const rules = {
    name:    { el: 'full-name',  err: 'name-error',    fn: v => v.trim().length >= 3 },
    phone:   { el: 'phone',      err: 'phone-error',   fn: v => /^(0\d{9}|(\+213)\d{9})$/.test(v.trim().replace(/\s/g,'')) },
    wilaya:  { el: 'wilaya',     err: 'wilaya-error',  fn: v => v !== '' },
    address: { el: 'address',    err: 'address-error', fn: v => v.trim().length >= 10 },
  };

  function validateField(key) {
    const rule = rules[key];
    const el   = document.getElementById(rule.el);
    const err  = document.getElementById(rule.err);
    if (!el || !err) return true;
    const valid = rule.fn(el.value);
    el.classList.toggle('error', !valid);
    err.classList.toggle('visible', !valid);
    return valid;
  }

  // Live validation on blur
  Object.keys(rules).forEach(key => {
    const el = document.getElementById(rules[key].el);
    if (el) el.addEventListener('blur', () => validateField(key));
  });

  // ── Submit ──
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validate all
    const valid = Object.keys(rules).map(validateField).every(Boolean);
    if (!valid) {
      const firstErr = form.querySelector('.form-input.error, .form-select.error, .form-textarea.error');
      firstErr?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    // Loading state
    const btnText = submitBtn.querySelector('.btn-text');
    const btnLoad = submitBtn.querySelector('.btn-loading');
    submitBtn.disabled = true;
    if (btnText) btnText.style.display = 'none';
    if (btnLoad) btnLoad.style.display = 'flex';

    try {
      const data = Object.fromEntries(new FormData(form));

      const res = await fetch('/api/order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(data),
      });

      if (res.ok) {
        form.style.display = 'none';
        if (successEl) successEl.style.display = 'flex';
        successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });

        // FB Pixel Purchase event
        if (typeof fbq !== 'undefined') {
          const qty = parseInt(data.quantity || '1', 10);
          fbq('track', 'Purchase', {
            value:    qty * PRODUCT_PRICE,
            currency: 'DZD',
            content_name: 'HOCO J101B Astute 30000mAh',
          });
        }
      } else {
        throw new Error('Server error: ' + res.status);
      }
    } catch (err) {
      console.error('Order submit error:', err);
      if (errorEl) errorEl.style.display = 'block';
      errorEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } finally {
      submitBtn.disabled = false;
      if (btnText) btnText.style.display = '';
      if (btnLoad) btnLoad.style.display = 'none';
    }
  });
})();
</script>
